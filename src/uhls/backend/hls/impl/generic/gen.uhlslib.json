{
  "components": {
    "GEN_ALU": {
      "kind": "combinational",
      "hdl": {
        "language": "verilog",
        "module": "GEN_ALU",
        "source": "src/uhls/backend/hls/impl/generic/gen_alu.v"
      },
      "ports": {
        "a": { "dir": "input", "type": "i32" },
        "b": { "dir": "input", "type": "i32" },
        "op": { "dir": "input", "type": "u5" },
        "y": { "dir": "output", "type": "i32" }
      },
      "supports": {
        "add": { "ii": 1, "d": 1, "opcode": 0, "bind": { "a": "operand0", "b": "operand1", "y": "result" } },
        "and": { "ii": 1, "d": 1, "opcode": 1, "bind": { "a": "operand0", "b": "operand1", "y": "result" } },
        "eq": { "ii": 1, "d": 1, "opcode": 2, "bind": { "a": "operand0", "b": "operand1", "y": "result" } },
        "ge": { "ii": 1, "d": 1, "opcode": 3, "bind": { "a": "operand0", "b": "operand1", "y": "result" } },
        "gt": { "ii": 1, "d": 1, "opcode": 4, "bind": { "a": "operand0", "b": "operand1", "y": "result" } },
        "le": { "ii": 1, "d": 1, "opcode": 5, "bind": { "a": "operand0", "b": "operand1", "y": "result" } },
        "lt": { "ii": 1, "d": 1, "opcode": 6, "bind": { "a": "operand0", "b": "operand1", "y": "result" } },
        "mov": { "ii": 1, "d": 1, "opcode": 7, "bind": { "a": "operand0", "y": "result" } },
        "ne": { "ii": 1, "d": 1, "opcode": 8, "bind": { "a": "operand0", "b": "operand1", "y": "result" } },
        "neg": { "ii": 1, "d": 1, "opcode": 9, "bind": { "a": "operand0", "y": "result" } },
        "not": { "ii": 1, "d": 1, "opcode": 10, "bind": { "a": "operand0", "y": "result" } },
        "or": { "ii": 1, "d": 1, "opcode": 11, "bind": { "a": "operand0", "b": "operand1", "y": "result" } },
        "shl": { "ii": 1, "d": 1, "opcode": 12, "bind": { "a": "operand0", "b": "operand1", "y": "result" } },
        "shr": { "ii": 1, "d": 1, "opcode": 13, "bind": { "a": "operand0", "b": "operand1", "y": "result" } },
        "sub": { "ii": 1, "d": 1, "opcode": 14, "bind": { "a": "operand0", "b": "operand1", "y": "result" } },
        "xor": { "ii": 1, "d": 1, "opcode": 15, "bind": { "a": "operand0", "b": "operand1", "y": "result" } }
      }
    },
    "GEN_MUL_PSEUDOPIPE_II1D3": {
      "kind": "pipelined",
      "hdl": {
        "language": "verilog",
        "module": "GEN_MUL_PSEUDOPIPE_II1D3",
        "source": "src/uhls/backend/hls/impl/generic/gen_mul.v"
      },
      "ports": {
        "clk": { "dir": "input", "type": "clock" },
        "rst": { "dir": "input", "type": "reset", "kind": "sync", "active": "hi" },
        "a": { "dir": "input", "type": "i32" },
        "b": { "dir": "input", "type": "i32" },
        "y_hi": { "dir": "output", "type": "i32" },
        "y_lo": { "dir": "output", "type": "i32" }
      },
      "supports": {
        "mul": { "ii": 1, "d": 2, "bind": { "a": "operand0", "b": "operand1", "y_lo": "result" } }
      }
    },
    "GEN_DIV_PSEUDOPIPE_II1D3": {
      "kind": "pipelined",
      "hdl": {
        "language": "verilog",
        "module": "GEN_DIV_PSEUDOPIPE_II1D3",
        "source": "src/uhls/backend/hls/impl/generic/gen_div.v",
        "parameters": {
          "W": "$bits(base_t)"
        }
      },
      "parameters": {
        "base_t": { "kind": "type", "required": true }
      },
      "ports": {
        "clk": { "dir": "input", "type": "clock" },
        "rst": { "dir": "input", "type": "reset", "kind": "sync", "active": "hi" },
        "a": { "dir": "input", "type": "base_t" },
        "b": { "dir": "input", "type": "base_t" },
        "op": { "dir": "input", "type": "u1" },
        "div": { "dir": "output", "type": "base_t" },
        "mod": { "dir": "output", "type": "base_t" }
      },
      "supports": {
        "div": {
          "ii": 1,
          "d": 3,
          "opcode": 0,
          "types": { "operand0": "base_t", "operand1": "base_t", "result": "base_t" },
          "bind": { "a": "operand0", "b": "operand1", "div": "result" }
        },
        "mod": {
          "ii": 1,
          "d": 3,
          "opcode": 1,
          "types": { "operand0": "base_t", "operand1": "base_t", "result": "base_t" },
          "bind": { "a": "operand0", "b": "operand1", "mod": "result" }
        }
      }
    },
    "GEN_FF_MEM": {
      "kind": "memory",
      "hdl": {
        "language": "verilog",
        "module": "GEN_FF_MEM",
        "source": "src/uhls/backend/hls/impl/generic/gen_ff_mem.v",
        "parameters": {
          "W": "$bits(word_t)",
          "DEPTH": "word_len"
        }
      },
      "parameters": {
        "word_t": { "kind": "type", "required": true },
        "word_len": { "kind": "int", "required": true },
        "impl": { "kind": "string" }
      },
      "ports": {
        "clk": { "dir": "input", "type": "clock" },
        "addr": { "dir": "input", "type": "i32" },
        "wdata": { "dir": "input", "type": "word_t" },
        "we": { "dir": "input", "type": "i1" },
        "rdata": { "dir": "output", "type": "word_t" }
      },
      "supports": {
        "load": { "ii": 1, "d": 1, "mode": "read", "bind": { "addr": "operand1", "rdata": "result", "we": "false" } },
        "store": { "ii": 1, "d": 1, "mode": "write", "bind": { "addr": "operand1", "wdata": "operand2", "we": "true" } }
      }
    }
  }
}
